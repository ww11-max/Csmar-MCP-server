# CSMAR MCP Server 配置文件
# 复制此文件为 .env:  cp .env.example .env
# 或通过 .mcp.json 的 env 字段直接设置环境变量
# ============================================================

# ==================== CSMAR 登录凭据 ====================
# 获取方式:
#   1. 访问 us.gtadata.com 注册个人账号
#   2. 联系学校图书馆绑定机构权限
#   3. 如使用校园网IP认证，可留空
CSMAR_USERNAME=your_csmar_username
CSMAR_PASSWORD=your_csmar_password

# 语言: 0=中文, 1=英文
CSMAR_LANG=0

# ==================== Python 设置 ====================
# 可选: 指定 Python 可执行文件路径 (默认自动检测)
# PYTHON_PATH=D:\python\python.exe
# PYTHON_PATH=/usr/local/bin/python3

# 可选: 指定 CSMAR SDK 所在目录
# CSMAR_SDK_PATH=D:\python\Lib\site-packages\csmarapi

# ==================== 服务器设置 ====================
PORT=3001
LOG_LEVEL=info
TIMEOUT=30000
MAX_RETRIES=3

# ==================== 备用: HTTP API 设置 ====================
# 如果 Python SDK 不可用，可配置 HTTP API
# CSMAR_API_BASE=https://api.gtarsc.com
# CSMAR_API_KEY=your_api_key_if_available
