{
  "name": "csmar-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for CSMAR (China Stock Market & Accounting Research) database",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "echo '{\"action\":\"check_availability\",\"params\":{}}' | python src/python_client.py --once",
    "test:persistent": "python src/python_client.py"
  },
  "engines": {
    "node": ">=18",
    "python": ">=3.8"
  },
  "keywords": [
    "mcp",
    "csmar",
    "financial",
    "data",
    "china",
    "stock",
    "accounting"
  ],
  "author": "ww11-max",
  "license": "MIT",
  "homepage": "https://github.com/ww11-max/Csmar-MCP-server",
  "bugs": {
    "url": "https://github.com/ww11-max/Csmar-MCP-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "zod": "^3.22.0"
  },
  "optionalDependencies": {
    "axios": "^1.6.0"
  }
}
